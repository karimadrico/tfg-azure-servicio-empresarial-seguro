{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "logicAppName": {
      "type": "string",
      "defaultValue": "logic-tfg-incidencias"
    },
    "location": {
      "type": "string",
      "defaultValue": "westeurope"
    },
    "apiBaseUrl": {
      "type": "string",
      "metadata": {
        "description": "URL base de la API desplegada en App Service"
      }
    },
    "apiKey": {
      "type": "securestring",
      "metadata": {
        "description": "Token Bearer almacenado en Key Vault"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('logicAppName')]",
      "location": "[parameters('location')]",
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "apiBaseUrl": {
              "type": "string",
              "defaultValue": "[parameters('apiBaseUrl')]"
            },
            "apiKey": {
              "type": "securestring",
              "defaultValue": "[parameters('apiKey')]"
            }
          },
          "triggers": {
            "manual": {
              "type": "Request",
              "kind": "Http",
              "inputs": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "titulo": { "type": "string" },
                    "descripcion": { "type": "string" },
                    "reportado_por": { "type": "string" },
                    "prioridad": { "type": "string" }
                  },
                  "required": ["titulo", "descripcion", "reportado_por"]
                }
              }
            }
          },
          "actions": {
            "Crear_incidencia_en_API": {
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "@{concat(parameters('apiBaseUrl'), '/incidencias')}",
                "headers": {
                  "Content-Type": "application/json",
                  "Authorization": "@{concat('Bearer ', parameters('apiKey'))}"
                },
                "body": "@triggerBody()"
              },
              "runAfter": {}
            },
            "Respuesta": {
              "type": "Response",
              "kind": "Http",
              "inputs": {
                "statusCode": 201,
                "headers": {
                  "Content-Type": "application/json"
                },
                "body": {
                  "mensaje": "Incidencia registrada mediante Logic App",
                  "incidencia": "@body('Crear_incidencia_en_API')"
                }
              },
              "runAfter": {
                "Crear_incidencia_en_API": ["Succeeded"]
              }
            }
          },
          "outputs": {}
        }
      }
    }
  ]
}
